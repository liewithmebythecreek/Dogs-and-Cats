# Model weights (tracked by DVC, not git)
*.h5
*.pkl
*.pt
*.pth
*.onnx
*.weights
/models/
/model/

# Runtime data files (generated at runtime — never commit)
backend/data/forecast_log.jsonl
backend/data/forecast_log.jsonl.old
backend/data/recent_30d.pkl
backend/data/*.pkl
backend/mlruns/

# Logs
*.log
/logs/
error_log.txt

# Environment variables
.env
.env.local

# Cache and temporary files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.cache/
.cache.sqlite
backend/.cache.sqlite
node_modules/
.npm/
dist/
build/
.DS_Store

# Do NOT ignore markdown — docs are important
# *.md   ← removed: was accidentally hiding all documentation

# But still ignore generated text outputs
error_log.txt

# Keep essential files even if patterns above would match
!README.md
!requirements.txt
!backend/data/.gitkeep

.dvc/config.local